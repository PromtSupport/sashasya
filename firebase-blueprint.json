{
  "entities": {
    "Folder": {
      "title": "Folder",
      "description": "A directory in the shared workspace",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "parentId": { "type": ["string", "null"] },
        "createdAt": { "type": "string", "description": "ISO timestamp" },
        "updatedAt": { "type": "string", "description": "ISO timestamp" }
      },
      "required": ["name", "createdAt", "updatedAt"]
    },
    "FileRecord": {
      "title": "File Record",
      "description": "A file in the shared workspace",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "parentId": { "type": ["string", "null"] },
        "size": { "type": "string" },
        "type": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["name", "size", "type", "content", "createdAt", "updatedAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A task in the shared kanban board",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "progress", "done"] },
        "assignee": { "type": "string" },
        "deadline": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "description", "status", "assignee", "deadline", "createdAt", "updatedAt"]
    },
    "Event": {
      "title": "Event",
      "description": "A shared calendar event",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "time": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "time", "date", "createdAt", "updatedAt"]
    },
    "SafeEntry": {
      "title": "Safe Entry",
      "description": "A secure credential entry",
      "type": "object",
      "properties": {
        "service": { "type": "string" },
        "login": { "type": "string" },
        "password": { "type": "string" },
        "note": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["service", "login", "password", "note", "createdAt", "updatedAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile with personal settings",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "theme": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["username", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User Profiles"
    },
    "/folders/{folderId}": {
      "schema": { "$ref": "#/entities/Folder" },
      "description": "Folder hierarchy"
    },
    "/files/{fileId}": {
      "schema": { "$ref": "#/entities/FileRecord" },
      "description": "File entries"
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Kanban workspace tasks"
    },
    "/events/{eventId}": {
      "schema": { "$ref": "#/entities/Event" },
      "description": "Calendar events"
    },
    "/safeEntries/{safeId}": {
      "schema": { "$ref": "#/entities/SafeEntry" },
      "description": "Secure passwords and API credentials"
    }
  }
}
